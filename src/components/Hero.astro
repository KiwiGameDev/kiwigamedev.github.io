---
// Hero section component
---

<section class="min-h-[40vh] flex items-center justify-center pt-16 px-4 sm:px-6 lg:px-8">
  <div class="max-w-6xl mx-auto text-left">
    <div class="space-y-8">
      <!-- Main heading -->
      <div class="space-y-4">
        <h1 class="text-4xl text-accent drop-shadow-lg sm:text-6xl lg:text-7xl font-bold tracking-tight">
          Hey, I'm <span class="text-highlight drop-shadow-[0_2px_2px_rgba(0,0,0,0.8)]">Bruce Anakin Miranda</span>
        </h1>
        <p class="text-xl sm:text-2xl max-w-3xl leading-relaxed text-secondary">
          I've worked on games and graphics programming projects across various engines and technologies.
        </p>
      </div>
      
      <!-- Social links -->
      <div class="flex flex-wrap items-center justify-start gap-y-4 gap-x-6">
        <a 
          href="https://github.com/KiwiGameDev" 
          target="_blank" 
          rel="noopener noreferrer"
          class="group flex items-center space-x-2 hover:text-highlight transition-colors"
