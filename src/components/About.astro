---
// About section component
---

<section id="about" class="py-20 px-4 sm:px-6 lg:px-8">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-pale-yellow mb-4">
        About Me
      </h2>
      <div class="w-20 h-1 bg-gradient-to-r from-blue-400 to-purple-500 mx-auto"></div>
    </div>
    
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- About text -->
      <div class="space-y-6">
        <p class="text-lg text-pale-yellow leading-relaxed">
          I'm a passionate game developer with expertise in multiple game engines and a strong background in graphics programming. 
          I love creating engaging gameplay experiences and optimizing performance to deliver the best possible player experience.
        </p>
        <p class="text-lg text-pale-yellow leading-relaxed">
          My journey in game development spans across various platforms and technologies, from indie games to complex graphics programming projects. 
          I'm always eager to learn new techniques and push the boundaries of what's possible in interactive entertainment.
        </p>
      </div>
      
      <!-- Skills grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <div class="bg-gray-900/50 backdrop-blur-sm border border-gray-800 rounded-lg p-6 hover:border-blue-500/50 transition-colors">
          <div class="flex items-center mb-3">
            <div class="w-8 h-8 bg-blue-500/20 rounded-lg flex items-center justify-center mr-3">
              <svg class="w-4 h-4 text-blue-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-pale-yellow">Game Development</h3>
          </div>
          <p class="text-sm">Unity, Unreal Engine, Godot, & Other Game Engines</p>
        </div>
        
        <div class="bg-gray-900/50 backdrop-blur-sm border border-gray-800 rounded-lg p-6 hover:border-purple-500/50 transition-colors">
          <div class="flex items-center mb-3">
            <div class="w-8 h-8 bg-purple-500/20 rounded-lg flex items-center justify-center mr-3">
              <svg class="w-4 h-4 text-purple-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3z"/>
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-pale-yellow">Graphics Programming</h3>
          </div>
          <p class="text-sm">Vulkan, DirectX, OpenGL, Shaders</p>
        </div>
        
        <div class="bg-gray-900/50 backdrop-blur-sm border border-gray-800 rounded-lg p-6 hover:border-green-500/50 transition-colors">
          <div class="flex items-center mb-3">
            <div class="w-8 h-8 bg-green-500/20 rounded-lg flex items-center justify-center mr-3">
              <svg class="w-4 h-4 text-green-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M3 4a1 1 0 011-1h12a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1V4zM3 10a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H4a1 1 0 01-1-1v-6zM14 9a1 1 0 00-1 1v6a1 1 0 001 1h2a1 1 0 001-1v-6a1 1 0 00-1-1h-2z"/>
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-pale-yellow">Tools Development</h3>
          </div>
          <p class="text-sm">Editor tools, Asset pipelines & management</p>
        </div>
        
        <div class="bg-gray-900/50 backdrop-blur-sm border border-gray-800 rounded-lg p-6 hover:border-yellow-500/50 transition-colors">
          <div class="flex items-center mb-3">
            <div class="w-8 h-8 bg-yellow-500/20 rounded-lg flex items-center justify-center mr-3">
              <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-pale-yellow">Technical Art</h3>
          </div>
          <p class="text-sm">Shader development, Optimization</p>
        </div>
      </div>
    </div>
  </div>
</section>