<section id="projects" class="py-20 px-4 sm:px-6 lg:px-8 bg-highlight/5">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-5xl font-bold text-accent mb-4">
        Featured Projects
      </h2>
    </div>
    
    <!-- Filter buttons -->
    <div class="flex flex-wrap justify-center gap-4 mb-12">
      <button class="filter-btn active px-6 py-2 rounded-full text-sm font-medium transition-all duration-300 bg-[#363a4f] text-highlight" data-filter="featured">
        Featured
      </button>
      <button class="filter-btn px-6 py-2 rounded-full text-sm font-medium transition-all duration-300 bg-[#363a4f]/10 text-accent hover:bg-[#363a4f]/20" data-filter="graphics">
        Graphics
      </button>
      <button class="filter-btn px-6 py-2 rounded-full text-sm font-medium transition-all duration-300 bg-[#363a4f]/10 text-accent hover:bg-[#363a4f]/20" data-filter="personal">
        Personal Projects
      </button>
      <button class="filter-btn px-6 py-2 rounded-full text-sm font-medium transition-all duration-300 bg-[#363a4f]/10 text-accent hover:bg-[#363a4f]/20" data-filter="all">
        All
      </button>
    </div>
    
    <!-- Projects grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-8 projects-grid">
      {projects.map((project) => (
        <div class={`project-card bg-highlight/5 backdrop-blur-sm border border-highlight/10 rounded-lg overflow-hidden shadow-lg hover:shadow-2xl shadow-black/20 hover:shadow-black/70 hover:border-secondary transition-all duration-300 hover:transform hover:scale-105 ${project.category}`} data-category={project.category} style={project.category !== 'featured' ? 'display: none' : ''}>
          <div class="aspect-video overflow-hidden">
            <img 
              src={project.image} 
              alt={project.title}
              class="w-full h-full object-cover object-[center_20%] transition-transform duration-300 hover:scale-110"
              loading="lazy"
            />
          </div>
          <div class="p-6">
            <h3 class="text-2xl font-bold text-accent mb-2">{project.title}</h3>
            <p class="text-sm mb-4 leading-relaxed text-secondary/80">{project.description}</p>
            <div class="flex flex-wrap gap-2 mb-4">
              {project.tags.map((tag) => (
                <span class="px-3 py-1 text-xs font-medium bg-highlight/10 rounded-full text-secondary">
                  {tag}
                </span>
              ))}
            </div>
            <a 
              href={project.link} 
              target={project.link.startsWith('http') ? '_blank' : '_self'}
              rel={project.link.startsWith('http') ? 'noopener noreferrer' : ''}
              class="inline-flex items-center text-accent hover:text-highlight font-medium text-sm transition-colors group"
            >
              View Project
              <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  // Project filtering functionality
  document.addEventListener('DOMContentLoaded', function() {
    const filterButtons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const projectCards = document.querySelectorAll<HTMLElement>('.project-card');
    
    filterButtons.forEach(button => {
      button.addEventListener('click', function() {
        const filter = this.getAttribute('data-filter');
        
        // Update active button
        filterButtons.forEach(btn => {
          btn.classList.remove('active', 'bg-[#363a4f]', 'text-highlight');
          btn.classList.add('bg-[#363a4f]/10', 'text-accent');
        });
        this.classList.add('active', 'bg-[#363a4f]', 'text-highlight');
        this.classList.remove('bg-[#363a4f]/10', 'text-accent');
        
        // Filter projects
        projectCards.forEach(card => {
          const category = card.getAttribute('data-category');
          if (filter === 'all' || category === filter) {
            card.style.display = 'block';
            card.style.opacity = '0';
            setTimeout(() => {
              card.style.opacity = '1';
            }, 100);
          } else {
            card.style.opacity = '0';
            setTimeout(() => {
              card.style.display = 'none';
            }, 300);
          }
        });
      });
    });
  });
</script>