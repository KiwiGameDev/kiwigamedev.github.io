---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="God of War Sons of Sparta - Bruce M.">
  <Navigation />
  <main class="pt-16">
    <section class="py-20 px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <!-- Header -->
        <div class="mb-12">
          <a href="/" class="inline-flex items-center text-accent hover:text-highlight mb-6 transition-colors">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
            </svg>
            Back to Portfolio
          </a>
          <h1 class="text-4xl sm:text-5xl font-bold text-accent mb-4">God of War Sons of Sparta</h1>
        </div>

        <!-- Project Image -->
        <div class="mb-12">
          <img 
            src="/assets/img/sons_of_sparta.jpg" 
            alt="God of War Sons of Sparta"
            class="w-full rounded-lg shadow-2xl"
          />
        </div>

        <!-- Project Details -->
        <div class="grid md:grid-cols-3 gap-8 mb-12">
          <div class="bg-background/50 backdrop-blur-sm border border-accent/20 rounded-lg p-6">
            <h3 class="text-lg font-semibold text-accent mb-2">Technologies</h3>
            <div class="flex flex-wrap gap-2">
              <span class="px-3 py-1 text-xs font-medium bg-accent/10 text-secondary rounded-full">Unity</span>
              <span class="px-3 py-1 text-xs font-medium bg-accent/10 text-secondary rounded-full">Featured</span>
            </div>
          </div>
          
          <div class="bg-background/50 backdrop-blur-sm border border-accent/20 rounded-lg p-6">
            <h3 class="text-lg font-semibold text-accent mb-2">Category</h3>
            <p class="text-secondary">Featured</p>
          </div>
          
          <div class="bg-background/50 backdrop-blur-sm border border-accent/20 rounded-lg p-6">
            <h3 class="text-lg font-semibold text-accent mb-2">Status</h3>
            <p class="text-secondary">Released (2026)</p>
          </div>
        </div>

        <!-- Project Description -->
        <div class="prose prose-invert max-w-none">
          <h2 class="text-2xl font-bold text-accent mb-4">About This Project</h2>
          <p class="text-secondary leading-relaxed mb-6">
            God of War Sons of Sparta is a 2026 Metroidvania developed by Mega Cat Studios and Santa Monica Studio,
            and published by Sony Interactive Entertainment.
          </p>
          
          <h3 class="text-xl font-semibold text-accent mb-3">Key Contributions</h3>
          <ul class="text-secondary space-y-2 mb-6">
            <li>• Developed several core foundational systems concerning the game's orchestration & state management</li>
            <li>• Handled player's gameplay mechanics, combat systems, platforming physics, and visuals tooling</li>
            <li>• Mentored junior developers on best practices and code reviews</li>
            <li>• Implemented tooling for level designers and visual effects artists</li>
            <li>• Ensured project stability throughout production</li>
          </ul>

          <h3 class="text-xl font-semibold text-accent mb-3">Technical Highlights</h3>
          <p class="text-secondary leading-relaxed mb-6">
            The project involved pushing Unity's capabilities to its limits to achieve the high visual and performance standards 
            required for a title under Santa Monica Studios.
          </p>

          <div class="mt-12 text-center">
            <a 
              href="https://store.playstation.com/en-us/concept/10012744" 
              target="_blank" 
              rel="noopener noreferrer"
              class="inline-flex items-center px-8 py-4 bg-accent text-background font-bold rounded-full hover:bg-highlight transition-colors duration-300 shadow-lg"
            >
              View on PlayStation Store
              <svg class="w-6 h-6 ml-2" fill="currentColor" viewBox="0 0 512 512">
                <path d="M399.77,203c-.8-17.1-3.3-34.5-10.8-50.1a82.45,82.45,0,0,0-16.5-23.2,105.59,105.59,0,0,0-21.3-16.3c-17.1-10.2-37.5-17-84.4-31S192,64,192,64V422.3l79.9,25.7s.1-198.8.1-299.5v-3.8c0-9.3,7.5-16.8,16.1-16.8h.5c8.5,0,15.5,7.5,15.5,16.8V278c11,5.3,29.2,9.3,41.8,9.1a47.79,47.79,0,0,0,24-5.7,49.11,49.11,0,0,0,18.4-17.8,78.64,78.64,0,0,0,9.9-27.3C400.07,225.5,400.17,214.2,399.77,203Z"/><path d="M86.67,357.8c27.4-9.8,89.3-29.5,89.3-29.5V281.1s-76.5,24.8-111.3,37.1c-8.6,3.1-17.3,5.9-25.7,9.5-9.8,4.1-19.4,8.7-28.1,14.8a26.29,26.29,0,0,0-9.2,10.1,17.36,17.36,0,0,0-.5,13.6c2,5.1,5.8,9.3,10.1,12.6,7.8,5.9,17.1,9.5,26.4,12.2a262.42,262.42,0,0,0,88.4,13.3c14.5-.2,36-1.9,50-4.4v-42s-11,2.5-41.3,12.5c-4.6,1.5-9.2,3.3-14,4.3a104.87,104.87,0,0,1-21.6,2.2c-6.5-.3-13.2-.7-19.3-3.1-2.2-1-4.6-2.2-5.5-4.6-.8-2,.3-4,1.7-5.4C78.87,360.9,82.87,359.3,86.67,357.8Z"/><path d="M512,345.9c-.1-6-3.7-11.2-7.9-15-7.1-6.3-15.9-10.3-24.7-13.5-5.5-1.9-9.3-3.3-14.7-5-25.2-8.2-51.9-11.2-78.3-11.3-8,.3-23.1.5-31,1.4-21.9,2.5-67.3,15.4-67.3,15.4v48.8s67.5-21.6,96.5-31.8a94.43,94.43,0,0,1,30.3-4.6c6.5.2,13.2.7,19.4,3.1,2.2.9,4.5,2.2,5.5,4.5.9,2.6-.9,5-2.9,6.5-4.7,3.8-10.7,5.3-16.2,7.4-41,14.5-132.7,44.7-132.7,44.7v47s117.2-39.6,170.8-58.8c8.9-3.3,17.9-6.1,26.4-10.4,7.9-4,15.8-8.6,21.8-15.3A19.74,19.74,0,0,0,512,345.9Z"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
