---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="Renfield: Bring Your Own Blood - Bruce M.">
  <Navigation />
  <main class="pt-16">
    <section class="py-20 px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <!-- Header -->
        <div class="mb-12">
          <a href="/" class="inline-flex items-center text-accent hover:text-highlight mb-6 transition-colors">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
            </svg>
            Back to Portfolio
          </a>
          <h1 class="text-4xl sm:text-5xl font-bold text-accent mb-4">Renfield: Bring Your Own Blood</h1>
        </div>

        <!-- Project Image -->
        <div class="mb-12">
          <img 
            src="/assets/img/renfield_byob.jpg" 
            alt="Renfield: Bring Your Own Blood"
            class="w-full rounded-lg shadow-2xl"
          />
        </div>

        <!-- Project Details -->
        <div class="grid md:grid-cols-3 gap-8 mb-12">
          <div class="bg-background/50 backdrop-blur-sm border border-accent/20 rounded-lg p-6">
            <h3 class="text-lg font-semibold text-accent mb-2">Technologies</h3>
            <div class="flex flex-wrap gap-2">
              <span class="px-3 py-1 text-xs font-medium bg-accent/10 text-secondary rounded-full">Unity</span>
              <span class="px-3 py-1 text-xs font-medium bg-accent/10 text-secondary rounded-full">Featured</span>
            </div>
          </div>
          
          <div class="bg-background/50 backdrop-blur-sm border border-accent/20 rounded-lg p-6">
            <h3 class="text-lg font-semibold text-accent mb-2">Category</h3>
            <p class="text-secondary">Featured</p>
          </div>
          
          <div class="bg-background/50 backdrop-blur-sm border border-accent/20 rounded-lg p-6">
            <h3 class="text-lg font-semibold text-accent mb-2">Status</h3>
            <p class="text-secondary">Released (2023)</p>
          </div>
        </div>

        <!-- Project Description -->
        <div class="prose prose-invert max-w-none">
          <h2 class="text-2xl font-bold text-accent mb-4">About This Project</h2>
          <p class="text-secondary leading-relaxed mb-6">
            Renfield: Bring Your Own Blood is a 2023 horror roguelike shoot 'em up video game developed by Mega Cat Studios 
            and published by Skybound Games, based on the action horror film Renfield.
          </p>
          
          <h3 class="text-xl font-semibold text-accent mb-3">Key Contributions</h3>
          <ul class="text-secondary space-y-2 mb-6">
            <li>• Developed core roguelike gameplay mechanics and upgrade systems</li>
            <li>• Implemented complex enemy AI and boss battle behaviors</li>
            <li>• Optimized performance for large numbers of concurrent on-screen enemies</li>
            <li>• Integrated steam achievements and leaderboard functionality</li>
          </ul>

          <h3 class="text-xl font-semibold text-accent mb-3">Technical Highlights</h3>
          <p class="text-secondary leading-relaxed mb-6">
            The project utilized procedural generation to create unique levels and enemy patterns, enhancing replayability and challenge.
          </p>

          <div class="mt-12 text-center">
            <a 
              href="https://store.steampowered.com/app/2354600/Renfield_Bring_Your_Own_Blood/" 
              target="_blank" 
              rel="noopener noreferrer"
              class="inline-flex items-center px-8 py-4 bg-accent text-background font-bold rounded-full hover:bg-highlight transition-colors duration-300 shadow-lg"
            >
              View on Steam
              <svg class="w-6 h-6 ml-2" fill="currentColor" viewBox="0 0 32 32">
                <path d="M18.102 12.129c0-0 0-0 0-0.001 0-1.564 1.268-2.831 2.831-2.831s2.831 1.268 2.831 2.831c0 1.564-1.267 2.831-2.831 2.831-0 0-0 0-0.001 0h0c-0 0-0 0-0.001 0-1.563 0-2.83-1.267-2.83-2.83 0-0 0-0 0-0.001v0zM24.691 12.135c0-2.081-1.687-3.768-3.768-3.768s-3.768 1.687-3.768 3.768c0 2.081 1.687 3.768 3.768 3.768v0c2.080-0.003 3.765-1.688 3.768-3.767v-0zM10.427 23.76l-1.841-0.762c0.524 1.078 1.611 1.808 2.868 1.808 1.317 0 2.448-0.801 2.93-1.943l0.008-0.021c0.155-0.362 0.246-0.784 0.246-1.226 0-1.757-1.424-3.181-3.181-3.181-0.405 0-0.792 0.076-1.148 0.213l0.022-0.007 1.903 0.787c0.852 0.364 1.439 1.196 1.439 2.164 0 1.296-1.051 2.347-2.347 2.347-0.324 0-0.632-0.066-0.913-0.184l0.015 0.006zM15.974 1.004c-7.857 0.001-14.301 6.046-14.938 13.738l-0.004 0.054 8.038 3.322c0.668-0.462 1.495-0.737 2.387-0.737 0.001 0 0.002 0 0.002 0h-0c0.079 0 0.156 0.005 0.235 0.008l3.575-5.176v-0.074c0.003-3.12 2.533-5.648 5.653-5.648 3.122 0 5.653 2.531 5.653 5.653s-2.531 5.653-5.653 5.653h-0.131l-5.094 3.638c0 0.065 0.005 0.131 0.005 0.199 0 0.001 0 0.002 0 0.003 0 2.342-1.899 4.241-4.241 4.241-2.047 0-3.756-1.451-4.153-3.38l-0.005-0.027-5.755-2.383c1.841 6.345 7.601 10.905 14.425 10.905 8.281 0 14.994-6.713 14.994-14.994s-6.713-14.994-14.994-14.994c-0 0-0.001 0-0.001 0h0z"></path>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
